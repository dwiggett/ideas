generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  phone         String?
  company       String?
  trade         String?
  state         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  quotes        Quote[]
  templates     QuoteTemplate[]
  @@map("users")
}

model QuoteTemplate {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  trade         String
  description   String?
  items         QuoteItemTemplate[]
  markup        Float     @default(20)
  taxRate       Float     @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  @@map("quote_templates")
}

model QuoteItemTemplate {
  id              String    @id @default(cuid())
  templateId      String
  template        QuoteTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  unitPrice       Float
  unit            String    @default("each")
  quantity        Float     @default(1)
  sortOrder       Int       @default(0)
  @@map("quote_item_templates")
}

model Quote {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId      String?
  clientName      String?
  clientEmail     String?
  clientPhone     String?
  clientAddress   String?
  projectName     String?
  projectDescription String?
  status          String    @default("draft")
  items           QuoteItem[]
  subtotal        Float     @default(0)
  taxRate         Float     @default(0)
  taxAmount       Float     @default(0)
  markup          Float     @default(20)
  markupAmount    Float     @default(0)
  total           Float     @default(0)
  notes           String?
  validUntil      DateTime?
  sentAt          DateTime?
  viewedAt        DateTime?
  acceptedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  @@map("quotes")
}

model QuoteItem {
  id              String    @id @default(cuid())
  quoteId         String
  quote           Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  unitPrice       Float
  unit            String    @default("each")
  quantity        Float     @default(1)
  totalPrice      Float     @default(0)
  sortOrder       Int       @default(0)
  @@map("quote_items")
}

model ServiceTemplate {
  id              String    @id @default(cuid())
  name            String
  category        String
  description     String?
  basePrice       Float
  unit            String    @default("each")
  typicalMarkup   Float     @default(20)
  materials       Json?
  laborHours      Float?
  difficulty      String    @default("medium")
  createdAt       DateTime  @default(now())
  @@map("service_templates")
}
